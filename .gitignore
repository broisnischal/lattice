# dependencies
node_modules/
frontend/node_modules/

# build output
frontend/dist/
zig-out/
.zig-cache/
zig-cache/

# fetched Native SDK framework (CI clones this next to the repo)
/../native-sdk/

# logs / os
*.log
.DS_Store
Thumbs.db

# scratch
*.tmp

# Capacitor / mobile native build output.
# The generated frontend/android + frontend/ios PROJECTS are committed (CI needs
# them); only their build artifacts and copied web assets are ignored. Each
# native project also has its own .gitignore — these are defense-in-depth plus
# the APK/AAB that CI copies to the workspace root.
frontend/android/app/build/
frontend/android/build/
frontend/android/.gradle/
frontend/android/app/src/main/assets/public/
frontend/ios/App/build/
frontend/ios/App/Pods/
frontend/ios/App/App/public/
frontend/ios/DerivedData/
DerivedData/
*.apk
*.aab
*.ipa
